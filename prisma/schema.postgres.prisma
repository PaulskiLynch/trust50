generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DATABASE_URL")
}

enum GroupStatus {
  draft
  emerging
  active
}

enum MembershipRole {
  owner
  member
  invitee
}

enum MembershipStatus {
  invited
  pending
  active
  waitlist
}

enum RequestStatus {
  open
  closed
}

enum DiscussionKind {
  request
  question
  insight
  update
}

enum OutcomeType {
  decision_made
  hire_completed
  introduced_to_someone
  direction_clarified
  no_longer_pursuing
}

enum IntroductionStatus {
  pending
  accepted
  declined
}

enum ConversationKind {
  direct
  introduction
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  name                  String?
  bio                   String?
  company               String?
  role                  String?
  passwordHash          String?
  isAdmin               Boolean        @default(false)
  avatarUrl             String?
  headline              String?
  linkedinUrl           String?
  whatsappNumber        String?
  phoneNumber           String?
  workEmail             String?
  personalEmail         String?
  createdAt             DateTime       @default(now())
  ownedGroups           Group[]        @relation("OwnedGroups")
  memberships           Membership[]
  recommendationsMade   Membership[]   @relation("MembershipRecommendations")
  membershipVotes       MembershipVote[]
  requests              Request[]
  introductionsOffered  Introduction[] @relation("IntroductionsOffered")
  introductionsReceived Introduction[] @relation("IntroductionsReceived")
  conversationsStarted  Conversation[] @relation("ConversationStarter")
  conversationsJoined   Conversation[] @relation("ConversationRecipient")
  messagesSent          Message[]
  repliesSent           Reply[]
}

model Group {
  id            String         @id @default(cuid())
  name          String
  description   String?
  whoFor        String
  whoNotFor     String
  valueProp     String
  ownerId       String
  owner         User           @relation("OwnedGroups", fields: [ownerId], references: [id])
  price         Int?
  status        GroupStatus    @default(draft)
  memberCount   Int            @default(0)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  memberships   Membership[]
  requests      Request[]
  conversations Conversation[]
}

model Membership {
  id                  String           @id @default(cuid())
  userId              String
  groupId             String
  recommendedByUserId String?
  role                MembershipRole
  status              MembershipStatus
  fitWhy              String?
  contributionWhy     String?
  relevantContext     String?
  createdAt           DateTime         @default(now())
  user                User             @relation(fields: [userId], references: [id])
  group               Group            @relation(fields: [groupId], references: [id])
  recommendedBy       User?            @relation("MembershipRecommendations", fields: [recommendedByUserId], references: [id])
  votes               MembershipVote[]

  @@unique([userId, groupId])
}

model MembershipVote {
  id           String      @id @default(cuid())
  membershipId String
  voterId      String
  createdAt    DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id])
  voter        User        @relation(fields: [voterId], references: [id])

  @@unique([membershipId, voterId])
}

model Request {
  id            String         @id @default(cuid())
  title         String?
  content       String
  kind          DiscussionKind @default(request)
  creatorId     String
  groupId       String
  status        RequestStatus  @default(open)
  outcome       String?
  outcomeType   OutcomeType?
  helpfulSource String?
  resolvedAt    DateTime?
  pinned        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  creator       User           @relation(fields: [creatorId], references: [id])
  group         Group          @relation(fields: [groupId], references: [id])
  introductions Introduction[]
  replies       Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  requestId String
  senderId  String
  body      String
  signal    String?
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
}

model Introduction {
  id           String             @id @default(cuid())
  requestId    String
  connectorId  String
  targetUserId String
  note         String?
  status       IntroductionStatus @default(pending)
  createdAt    DateTime           @default(now())
  acceptedAt   DateTime?
  request      Request            @relation(fields: [requestId], references: [id])
  connector    User               @relation("IntroductionsOffered", fields: [connectorId], references: [id])
  targetUser   User               @relation("IntroductionsReceived", fields: [targetUserId], references: [id])
  conversation Conversation?

  @@unique([requestId, connectorId, targetUserId])
}

model Conversation {
  id               String           @id @default(cuid())
  introId          String?          @unique
  groupId          String?
  kind             ConversationKind @default(direct)
  directKey        String?          @unique
  participantOneId String
  participantTwoId String
  createdAt        DateTime         @default(now())
  introduction     Introduction?    @relation(fields: [introId], references: [id])
  group            Group?           @relation(fields: [groupId], references: [id])
  participantOne   User             @relation("ConversationStarter", fields: [participantOneId], references: [id])
  participantTwo   User             @relation("ConversationRecipient", fields: [participantTwoId], references: [id])
  messages         Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}
